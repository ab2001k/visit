    <script>
        const words = ["Designer", "Wish Maker", "Web Developer", "Creator"];
        let i = 0;
        let timer;
        let isDeleting = false;
        let txt = '';
        const speed = 100; // Typing speed
        const deleteSpeed = 50; // Deleting speed
        const pauseTime = 2000; // Pause at end of word

        function typeWriter() {
            const currentWord = words[i];
            
            if (isDeleting) {
                txt = currentWord.substring(0, txt.length - 1);
            } else {
                txt = currentWord.substring(0, txt.length + 1);
            }

            document.getElementById("typewriter").textContent = txt;

            let typeSpeed = isDeleting ? deleteSpeed : speed;

            if (!isDeleting && txt === currentWord) {
                typeSpeed = pauseTime;
                isDeleting = true;
            } else if (isDeleting && txt === '') {
                isDeleting = false;
                i++;
                if (i >= words.length) i = 0;
                typeSpeed = 500; // Pause before typing next word
            }

            setTimeout(typeWriter, typeSpeed);
        }

        // Start typing effect when page loads
        window.onload = () => {
            setTimeout(typeWriter, 500);
        };
    </script>
