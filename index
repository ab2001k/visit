    <script>
        const words = ["Wish Links", "Wedding Websites", "Digital Portfolios", "Web Games"];
        let i = 0;
        let timer;
        let isDeleting = false;
        let txt = '';
        const speed = 100;
        const deleteSpeed = 50;
        const pauseTime = 2000;

        function typeWriter() {
            const currentWord = words[i];
            
            if (isDeleting) {
                txt = currentWord.substring(0, txt.length - 1);
            } else {
                txt = currentWord.substring(0, txt.length + 1);
            }

            document.getElementById("typewriter").textContent = txt;

            let typeSpeed = isDeleting ? deleteSpeed : speed;

            if (!isDeleting && txt === currentWord) {
                typeSpeed = pauseTime;
                isDeleting = true;
            } else if (isDeleting && txt === '') {
                isDeleting = false;
                i++;
                if (i >= words.length) i = 0;
                typeSpeed = 500;
            }

            setTimeout(typeWriter, typeSpeed);
        }

        window.onload = () => {
            setTimeout(typeWriter, 500);
        };
    </script>
